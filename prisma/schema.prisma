// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model StoreSettings {
  id        String   @id
  storeName String?
  taxRate   Decimal  @db.Decimal(5, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  tags        String[]        @default([])
  basePrice   Decimal         @db.Decimal(10, 2)
  imageUrl    String?
  isActive    Boolean         @default(true)
  isSoldOut   Boolean         @default(false)
  sortOrder   Int             @default(0)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  groups      ModifierGroup[]
  templateLinks MenuItemModifierTemplate[]
  orderItems  OrderItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ModifierTemplate {
  id          String                   @id @default(cuid())
  name        String
  type        ModifierType
  required    Boolean                  @default(false)
  multiSelect Boolean                  @default(false)
  options     ModifierTemplateOption[]
  groups      ModifierGroup[]
  menuItems   MenuItemModifierTemplate[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model ModifierTemplateOption {
  id                 String           @id @default(cuid())
  name               String
  priceDelta         Decimal          @default(0) @db.Decimal(10, 2)
  sortOrder          Int              @default(0)
  modifierTemplateId String
  modifierTemplate   ModifierTemplate @relation(fields: [modifierTemplateId], references: [id], onDelete: Cascade)

  @@index([modifierTemplateId, sortOrder])
}

model MenuItemModifierTemplate {
  menuItemId         String
  modifierTemplateId String
  sortOrder          Int              @default(0)
  menuItem           MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierTemplate   ModifierTemplate @relation(fields: [modifierTemplateId], references: [id], onDelete: Cascade)

  @@id([menuItemId, modifierTemplateId])
  @@index([menuItemId, sortOrder])
}

model ModifierGroup {
  id          String           @id @default(cuid())
  name        String
  type        ModifierType
  required    Boolean          @default(false)
  multiSelect Boolean          @default(false)
  menuItemId  String
  templateId  String?
  menuItem    MenuItem         @relation(fields: [menuItemId], references: [id])
  template    ModifierTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  options     ModifierOption[]
}

model ModifierOption {
  id              String        @id @default(cuid())
  name            String
  priceDelta      Decimal       @default(0) @db.Decimal(10, 2)
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id])
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  phone        String
  status       OrderStatus @default(PENDING)
  subtotal     Decimal     @db.Decimal(10, 2)
  tax          Decimal     @db.Decimal(10, 2)
  taxRateApplied Decimal   @db.Decimal(5, 4)
  total        Decimal     @db.Decimal(10, 2)
  notes        String?
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id         String              @id @default(cuid())
  orderId    String
  order      Order               @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal             @db.Decimal(10, 2)
  modifiers  OrderItemModifier[]
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  name        String
  priceDelta  Decimal   @default(0) @db.Decimal(10, 2)
}

enum OrderStatus {
  PENDING
  PAID
  MAKING
  READY
  COMPLETED
  CANCELED
}

enum ModifierType {
  SIZE
  SUGAR
  ICE
  TOPPING
  OTHER
}
